# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
# Secret key (new format sb_secret_... or legacy service_role JWT).
# Backend only, NEVER expose to frontend. Bypasses RLS.
SUPABASE_SERVICE_KEY=your-secret-key
# Optional / unused: tokens are verified via the JWKS endpoint (ES256).
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=

# --- App encryption ---
# Fernet key for encrypting exchange API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key

# --- App ---
ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Notifications email (optionnel) ---
# Sans clé : notifications in-app seulement. Avec clé Resend : email en plus.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Cadence <notifications@tondomaine.com>
